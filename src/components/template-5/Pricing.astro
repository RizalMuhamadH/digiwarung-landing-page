---
import { Check, AlertCircle } from "@lucide/astro";
---

<section id="pricing" class="pricing-5 section">
  <div class="container">
    <div class="pricing-card">
      <div class="pricing-header">
        <div class="promo-badge">PROMO TERBATAS: SISA 12 SLOT HARI INI</div>
        <h2>Dapatkan Akses Clipcash AI</h2>
        <p>Gabung dengan 2400+ clipper lainnya dan mulai raih penghasilan 2 digit.</p>
      </div>

      <div class="pricing-body">
        <div class="price-box">
          <div class="old-price">Rp 599.000</div>
          <div class="current-price">
            <span class="currency">Rp</span>
            <span class="amount">199.000</span>
          </div>
          <p class="price-note">Sekali Bayar, Akses Seumur Hidup</p>
        </div>

        <div class="features-list">
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Akses Seumur Hidup Software Clipcash</span>
          </div>
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Sistem Panduan Clipcash (Step by Step)</span>
          </div>
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Workflow + 70 Agent Clipcash AI</span>
          </div>
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Checklist Harian Konsistensi</span>
          </div>
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Cara Viral Global & Lolos Monetisasi</span>
          </div>
          <div class="feature-item">
            <Check class="h-5 w-5 text-yellow" />
            <span>Support & Konsultasi Grup</span>
          </div>
        </div>

        <div class="pricing-actions">
          <a href="#" class="btn btn-yellow btn-full">AMBIL PROMO SEKARANG</a>
          <div class="guarantee-text">
            <AlertCircle class="h-4 w-4" />
            <span>Garansi 7 Hari Coba Dulu Atau Uang Kembali!</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-5 {
    padding: 100px 0;
    background: #0A0A0A;
  }

  .pricing-card {
    max-width: 800px;
    margin: 0 auto;
    background: #151515;
    border-radius: 40px;
    border: 2px solid var(--color-yellow, #FAB005);
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(250, 176, 5, 0.1);
  }

  .pricing-header {
    padding: 60px 40px 40px;
    text-align: center;
    background: radial-gradient(circle at center, rgba(250, 176, 5, 0.1), transparent);
  }

  .promo-badge {
    display: inline-block;
    background: #ff4b4b;
    color: white;
    padding: 6px 16px;
    border-radius: 50px;
    font-size: 12px;
    font-weight: 800;
    margin-bottom: 24px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); }
    50% { transform: scale(1.05); }
    100% { transform: scale(1); }
  }

  .pricing-header h2 {
    font-size: 36px;
    font-weight: 900;
    color: white;
    margin-bottom: 16px;
  }

  .pricing-header p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.6);
  }

  .pricing-body {
    padding: 0 60px 60px;
  }

  .price-box {
    text-align: center;
    margin-bottom: 48px;
  }

  .old-price {
    font-size: 20px;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: line-through;
    margin-bottom: 8px;
  }

  .current-price {
    color: var(--color-yellow, #FAB005);
    font-weight: 900;
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 8px;
  }

  .current-price .currency { font-size: 32px; margin-top: 10px; }
  .current-price .amount { font-size: 80px; line-height: 1; }

  .price-note {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 12px;
  }

  .features-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 48px;
    background: rgba(255, 255, 255, 0.03);
    padding: 32px;
    border-radius: 20px;
  }

  .feature-item {
    display: flex;
    gap: 12px;
    align-items: center;
    font-size: 15px;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 500;
  }

  .btn-full {
    width: 100%;
    display: block;
    text-align: center;
    padding: 24px;
    border-radius: 16px;
    font-size: 20px;
    font-weight: 900;
    background: var(--color-yellow, #FAB005);
    color: #0F0F0F;
    text-decoration: none;
    transition: 0.3s ease;
    box-shadow: 0 20px 40px rgba(250, 176, 5, 0.3);
  }

  .btn-full:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 60px rgba(250, 176, 5, 0.4);
  }

  .guarantee-text {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .pricing-body { padding: 0 30px 40px; }
    .features-list { grid-template-columns: 1fr; }
    .current-price .amount { font-size: 60px; }
  }
</style>
