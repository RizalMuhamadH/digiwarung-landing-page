---
import { Menu, X } from "@lucide/astro";
---

<header class="header-5">
  <div class="container flex-header">
    <div class="logo">
      <a href="/template-5">
        <span class="logo-icon">C</span>
        <span class="logo-text">ClipCash<span class="dot">.</span></span>
      </a>
    </div>
    
    <nav class="nav">
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#benefits">Why Us</a></li>
        <li><a href="#how-it-works">Workflow</a></li>
        <li><a href="#pricing">Pricing</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <a href="#pricing" class="btn btn-yellow">Akses Sekarang</a>
    </div>

    <button class="mobile-toggle" id="mobile-toggle-5">
      <Menu id="menu-icon" />
      <X id="close-icon" class="hidden" />
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu-5">
    <nav>
      <ul>
        <li><a href="#home">Home</a></li>
        <li><a href="#benefits">Why Us</a></li>
        <li><a href="#how-it-works">Workflow</a></li>
        <li><a href="#pricing">Pricing</a></li>
      </ul>
      <div class="mobile-actions">
        <a href="#pricing" class="btn btn-yellow">Akses Sekarang</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle-5");
  const menu = document.getElementById("mobile-menu-5");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("active");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });

  // Close menu when clicking a link
  const links = document.querySelectorAll("#mobile-menu-5 a");
  links.forEach(link => {
    link.addEventListener("click", () => {
      menu?.classList.remove("active");
      menuIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
    });
  });
</script>

<style>
  .header-5 {
    padding: 20px 0;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(15, 15, 15, 0.9);
    backdrop-filter: blur(10px);
    z-index: 1000;
    border-bottom: 1px solid rgba(250, 176, 5, 0.1);
  }

  .flex-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo a {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: var(--color-yellow, #FAB005);
    color: #0F0F0F;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-weight: 900;
    font-size: 20px;
  }

  .logo-text {
    font-size: 24px;
    font-weight: 800;
    color: white;
  }

  .dot { color: var(--color-yellow, #FAB005); }

  .nav ul {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav a {
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
    text-decoration: none;
    transition: var(--transition);
  }

  .nav a:hover {
    color: var(--color-yellow, #FAB005);
  }

  .btn-yellow {
    background: var(--color-yellow, #FAB005);
    color: #0F0F0F;
    font-weight: 700;
    padding: 10px 24px;
    border-radius: 8px;
    text-decoration: none;
    transition: var(--transition);
  }

  .btn-yellow:hover {
    background: #e6a200;
    transform: translateY(-2px);
  }

  .mobile-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: white;
  }

  .hidden { display: none; }

  .mobile-menu {
    position: fixed;
    top: 73px;
    left: 0;
    width: 100%;
    background: #0F0F0F;
    padding: 40px 20px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.5);
    transform: translateY(-100%);
    opacity: 0;
    transition: 0.3s ease;
    z-index: 999;
    border-bottom: 1px solid rgba(250, 176, 5, 0.1);
  }

  .mobile-menu.active {
    transform: translateY(0);
    opacity: 1;
  }

  .mobile-menu ul {
    list-style: none;
    padding: 0;
    margin-bottom: 32px;
  }

  .mobile-menu li {
    margin-bottom: 24px;
    text-align: center;
  }

  .mobile-menu a {
    font-size: 20px;
    font-weight: 600;
    color: white;
    text-decoration: none;
  }

  .mobile-actions {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 992px) {
    .nav, .header-actions { display: none; }
    .mobile-toggle { display: block; }
  }
</style>
