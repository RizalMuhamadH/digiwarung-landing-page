<style>
  .footer-2 {
    background: #191a15;
    color: white;
    padding: 100px 0 40px;
  }

  .footer-grid {
    display: flex;
    flex-direction: column;
    gap: 80px;
    margin-bottom: 80px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: var(--color-primary, #52bd94);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-weight: 800;
  }

  .logo-text {
    font-size: 24px;
    font-weight: 800;
    color: white;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 40px;
  }

  .footer-col h4 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 24px;
    color: white;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-col li {
    margin-bottom: 16px;
  }

  .footer-col a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 15px;
    transition: 0.3s ease;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .footer-col a:hover {
    color: white;
  }

  .badge {
    background: #6d5bff;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 800;
    color: white;
  }

  .icon-inline {
    width: 14px;
    height: 14px;
  }

  .footer-bottom {
    padding-top: 40px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.4);
  }

  .legal {
    display: flex;
    gap: 40px;
  }

  .legal-links {
    display: flex;
    gap: 20px;
  }

  .legal-links a {
    color: inherit;
    text-decoration: none;
  }

  .footer-settings {
    display: flex;
    gap: 32px;
  }

  .setting-item {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  @media (max-width: 992px) {
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
    .footer-bottom {
      flex-direction: column;
      gap: 32px;
      text-align: center;
    }
    .legal {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
