---
import { Image } from "astro:assets";
import dashboardImg from "../../assets/template-2/tools-dashboard.png";
---

<section id="tools" class="tools-section section">
  <div class="container">
    <div class="section-header text-center">
      <h2>All the <span class="text-underline">tools</span> that you need</h2>
      <p>
        Sed ut perspiciatis unde omnis iste natus error sit voluptatem
        accusantium doloremque laudantium, totam rem aperiam, eaque ipsa quae ab
        illo inventore veritatis et quasi architecto beatae vitae dicta sunt
        explicabo.
      </p>
    </div>

    <div class="dashboard-preview">
      <div class="browser-mockup">
        <div class="browser-header">
          <div class="dots">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="url-bar">DigiWarung.com</div>
        </div>
        <Image
          src={dashboardImg}
          alt="Dashboard Preview"
          class="dashboard-img"
        />
      </div>

      <!-- Decorative background shapes -->
      <div class="shape shape-yellow"></div>
    </div>

    <div class="app-icons-grid">
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/1/12/Google_Drive_icon_%282020%29.svg"
          alt="Google Drive"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/d/df/Google_Classroom_Icon.svg"
          alt="Google Classroom"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Google_Calendar_icon_%282020%29.svg"
          alt="Google Calendar"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/4/45/Notion_app_logo.png"
          alt="Notion"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/c/c9/Microsoft_Office_Teams_%282018%E2%80%93present%29.svg"
          alt="Teams"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/b/b9/Slack_Technologies_Logo.svg"
          alt="Slack"
        />
      </div>
      <div class="app-icon">
        <img
          src="https://upload.wikimedia.org/wikipedia/commons/b/b1/Zoom_Communications_Logo.svg"
          alt="Zoom"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .tools-section {
    background: #fdfdfd;
    position: relative;
    padding-bottom: 120px;
  }

  .text-center {
    text-align: center;
    margin: 0 auto 80px;
    max-width: 800px;
  }

  .section-header h2 {
    font-size: 56px;
    font-weight: 800;
    margin-bottom: 24px;
    color: #1a1a1a;
  }

  .text-underline {
    position: relative;
    display: inline-block;
  }

  .text-underline::after {
    content: "";
    position: absolute;
    bottom: 8px;
    left: 0;
    width: 100%;
    height: 8px;
    background: rgba(82, 189, 148, 0.3);
    z-index: -1;
  }

  .section-header p {
    font-size: 18px;
    color: #666;
    line-height: 1.8;
  }

  .dashboard-preview {
    position: relative;
    margin-bottom: 80px;
    z-index: 1;
  }

  .browser-mockup {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 50px 100px rgba(0, 0, 0, 0.08);
    border: 1px solid #eee;
  }

  .browser-header {
    background: #f5f5f5;
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 40px;
  }

  .dots {
    display: flex;
    gap: 8px;
  }

  .dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dots span:nth-child(1) {
    background: #ff5f56;
  }
  .dots span:nth-child(2) {
    background: #ffbd2e;
  }
  .dots span:nth-child(3) {
    background: #27c93f;
  }

  .url-bar {
    background: white;
    padding: 6px 40px;
    border-radius: 6px;
    font-size: 12px;
    color: #999;
    flex: 1;
    max-width: 400px;
    text-align: center;
  }

  .dashboard-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .shape {
    position: absolute;
    z-index: -1;
    border-radius: 40px;
  }

  .shape-yellow {
    width: 200px;
    height: 200px;
    background: #ffb352;
    right: -50px;
    bottom: -30px;
    transform: rotate(15deg);
    border-radius: 60px;
    opacity: 0.8;
  }

  .app-icons-grid {
    display: flex;
    justify-content: center;
    gap: 48px;
    flex-wrap: wrap;
    padding: 40px 0;
  }

  .app-icon {
    width: 64px;
    height: 64px;
    background: white;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.03);
    transition: var(--transition);
  }

  .app-icon:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.08);
  }

  .app-icon img {
    max-width: 100%;
    max-height: 100%;
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 36px;
    }
    .app-icons-grid {
      gap: 24px;
    }
    .app-icon {
      width: 48px;
      height: 48px;
    }
  }
</style>
