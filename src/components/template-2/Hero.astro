---
import { Image } from "astro:assets";
import teacherImg from "../../assets/template-2/hero-teacher.png";
import studentImg from "../../assets/template-2/hero-student.png";
import { Play } from "@lucide/astro";
---

<section class="hero-2">
  <div class="container flex-hero">
    <div class="hero-content">
      <h1 class="hero-title">Teach students <span class="text-highlight">worldwide</span></h1>
      <p class="hero-subtitle">
        Amet nunc diam sed duis at sit diam arcu, nec. Eleifend proin massa nisl et viverra viverra lectus pulvinar. Nunc diam sed duis at sit diam arcu, nec.
      </p>
      <div class="hero-cta">
        <a href="#" class="btn btn-primary btn-lg">Sign Up Now</a>
        <a href="#" class="btn btn-video">
          <span class="play-icon">
            <Play class="h-5 w-5 fill-dark" />
          </span>
          View Demo
        </a>
      </div>
      
      <div class="trusted-by">
        <p>Trusted by leading companies</p>
        <div class="brand-icons">
          <!-- Placeholder icons for brands -->
          <div class="brand-icon">★</div>
          <div class="brand-icon">●</div>
          <div class="brand-icon">◆</div>
          <div class="brand-icon">▲</div>
          <div class="brand-icon">■</div>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="image-stack">
        <div class="image-box box-1">
          <Image src={teacherImg} alt="Teacher" class="hero-img" />
          <div class="info-badge teacher-info">
             <p>Music, Art, Mathematics</p>
          </div>
        </div>
        <div class="image-box box-2">
          <Image src={studentImg} alt="Student" class="hero-img" />
          <div class="info-badge student-info">
             <p>Hi teacher!</p>
             <p class="sub">Please check my lesson</p>
          </div>
        </div>
      </div>
      
      <!-- Decorative UI floating elements -->
      <div class="floating-ui ui-1">
        <span>History, Mathematics, English</span>
      </div>
      <div class="floating-ui ui-2">
        <span>Finance, Art</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-2 {
    padding: 160px 0 100px;
    background: #fff;
    overflow: hidden;
  }

  .flex-hero {
    display: flex;
    align-items: center;
    gap: 80px;
  }

  .hero-content {
    flex: 1;
  }

  .hero-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 24px;
    color: #1a1a1a;
  }

  .text-highlight {
    color: var(--color-primary, #52BD94);
  }

  .hero-subtitle {
    font-size: 18px;
    color: #666;
    margin-bottom: 40px;
    line-height: 1.6;
    max-width: 500px;
  }

  .hero-cta {
    display: flex;
    gap: 32px;
    align-items: center;
    margin-bottom: 60px;
  }

  .btn-lg {
    padding: 18px 48px;
    font-size: 18px;
    border-radius: 50px;
  }

  .btn-video {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    color: #1a1a1a;
    text-decoration: none;
  }

  .play-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid #ddd;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .trusted-by p {
    font-size: 14px;
    font-weight: 600;
    color: #999;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .brand-icons {
    display: flex;
    gap: 32px;
    font-size: 24px;
    color: #ccc;
  }

  .hero-visual {
    flex: 1.2;
    position: relative;
    height: 600px;
  }

  .image-stack {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .image-box {
    position: absolute;
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
  }

  .box-1 {
    width: 320px;
    height: 400px;
    top: 50px;
    left: 0;
    z-index: 2;
  }

  .box-2 {
    width: 300px;
    height: 380px;
    top: 150px;
    right: 0;
    z-index: 1;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .info-badge {
    position: absolute;
    bottom: 20px;
    left: 20px;
    right: 20px;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(10px);
    padding: 12px 20px;
    border-radius: 15px;
    text-align: center;
  }

  .info-badge p {
    margin: 0;
    font-weight: 700;
    font-size: 14px;
    color: #1a1a1a;
  }

  .student-info .sub {
    font-size: 12px;
    font-weight: 500;
    color: #666;
    margin-top: 4px;
  }

  .floating-ui {
    position: absolute;
    background: white;
    padding: 12px 20px;
    border-radius: 50px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    font-size: 14px;
    font-weight: 600;
    color: #1a1a1a;
    z-index: 3;
    animation: float 6s ease-in-out infinite;
  }

  .ui-1 {
    top: 0;
    left: 250px;
  }

  .ui-2 {
    bottom: 50px;
    right: 280px;
    animation-delay: 1.5s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
  }

  @media (max-width: 1200px) {
    .hero-title { font-size: 60px; }
  }

  @media (max-width: 992px) {
    .flex-hero { flex-direction: column; text-align: center; }
    .hero-subtitle { margin: 0 auto 40px; }
    .hero-cta { justify-content: center; }
    .brand-icons { justify-content: center; }
    .hero-visual { height: 500px; margin-top: 60px; }
    .box-1 { width: 260px; height: 320px; left: 10%; }
    .box-2 { width: 240px; height: 300px; right: 10%; top: 120px; }
  }
</style>
