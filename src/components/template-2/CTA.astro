---
import { Image } from "astro:assets";
import p1 from "../../assets/template-2/person-1.png";
import p2 from "../../assets/template-2/person-2.png";
---

<section class="cta-2-section">
  <div class="container">
    <div class="cta-banner">
      <!-- Scattered background avatars -->
      <div class="avatar-scatter">
        <div class="sc-avatar av-1"><Image src={p1} alt="User" /></div>
        <div class="sc-avatar av-2"><Image src={p2} alt="User" /></div>
        <div class="sc-avatar av-3"><Image src={p1} alt="User" /></div>
        <div class="sc-avatar av-4"><Image src={p2} alt="User" /></div>
        <div class="sc-avatar av-5"><Image src={p1} alt="User" /></div>
        <div class="sc-avatar av-6"><Image src={p2} alt="User" /></div>
      </div>

      <div class="cta-content text-center">
        <h2>Join a world of learning</h2>
        <p>Melesuada sit ut etiam sit sit nisi, interdum etiam dignissim. Risus elit id fringilla habitant et facilisi.</p>
        <a href="#" class="btn btn-primary btn-lg">Sign Up Now</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-2-section {
    padding: 100px 0;
  }

  .cta-banner {
    background: #FFD54F;
    border-radius: 40px;
    padding: 120px 60px;
    position: relative;
    overflow: hidden;
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-content h2 {
    font-size: 56px;
    font-weight: 900;
    margin-bottom: 24px;
    color: #1a1a1a;
  }

  .cta-content p {
    font-size: 18px;
    color: #4a4a4a;
    margin-bottom: 40px;
    line-height: 1.6;
  }

  .avatar-scatter {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .sc-avatar {
    position: absolute;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid white;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .sc-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .av-1 { top: 20%; left: 10%; width: 80px; height: 80px; }
  .av-2 { bottom: 20%; left: 15%; width: 70px; height: 70px; }
  .av-3 { top: 15%; right: 10%; width: 90px; height: 90px; }
  .av-4 { bottom: 15%; right: 15%; width: 60px; height: 60px; }
  .av-5 { top: 50%; left: 5%; }
  .av-6 { top: 50%; right: 5%; }

  @media (max-width: 768px) {
    .cta-content h2 { font-size: 36px; }
    .cta-banner { padding: 80px 20px; }
    .avatar-scatter { display: none; }
  }
</style>
