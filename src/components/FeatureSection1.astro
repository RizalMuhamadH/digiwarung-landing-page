<section class="support-section section">
  <div class="container flex-support">
    <div class="support-info">
      <h2>How we support our partner all over the world</h2>
      <p>
        SaaS become a common delivery model for many business applications,
        including office software, messaging software, payroll processing
        software, DBMS software, management software.
      </p>

      <div class="ratings">
        <div class="rating-item">
          <div class="stars">★★★★★</div>
          <p><strong>4.9 / 5 rating</strong></p>
          <p>databricks</p>
        </div>
        <div class="rating-item">
          <div class="stars">★★★★★</div>
          <p><strong>4.8 / 5 rating</strong></p>
          <p>Chainanalysis</p>
        </div>
      </div>
    </div>

    <div class="support-features">
      <div class="feature-card">
        <div class="feature-icon icon-bg-1">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 19V5M12 5L5 12M12 5L19 12"
              stroke="#52BD94"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="feature-text">
          <h3>Publishing</h3>
          <p>
            Plan, collaborate, and publishing your content that drive's
            meaningful engagement and growth for your brand.
          </p>
        </div>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-bg-2">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M18 20V10M12 20V4M6 20V14"
              stroke="#52BD94"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="feature-text">
          <h3>Analytics</h3>
          <p>Analyze your performance and create gorgeous reports.</p>
        </div>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-bg-3">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M17 21V19C17 17.9391 16.5786 16.9217 15.8284 16.1716C15.0783 15.4214 14.0609 15 13 15H5C3.93913 15 2.92172 15.4214 2.17157 16.1716C1.42143 16.9217 1 17.9391 1 19V21M13 7C13 9.20914 11.2091 11 9 11C6.79086 11 5 9.20914 5 7C5 4.79086 6.79086 3 9 3C11.2091 3 13 4.79086 13 7Z"
              stroke="#52BD94"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <div class="feature-text">
          <h3>Engagement</h3>
          <p>Quiuckly navigate youanda engage with your audience.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .support-section {
    background-color: var(--color-bg-light);
  }

  .flex-support {
    display: flex;
    gap: 80px;
    align-items: flex-start;
  }

  .support-info {
    flex: 1;
  }

  .support-info h2 {
    font-size: 56px;
    font-weight: 800;
    margin-bottom: 32px;
    letter-spacing: -1px;
  }

  .support-info p {
    font-size: 20px;
    margin-bottom: 48px;
    color: var(--color-text);
    line-height: 1.8;
  }

  .ratings {
    display: flex;
    gap: 60px;
  }

  .stars {
    color: #ffb352;
    font-size: 24px;
    margin-bottom: 12px;
  }

  .rating-item p strong {
    font-size: 20px;
    color: var(--color-dark);
  }

  .rating-item p {
    font-size: 16px;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .support-features {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .feature-card {
    display: flex;
    gap: 32px;
    align-items: flex-start;
  }

  .feature-icon {
    width: 72px;
    height: 72px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: white;
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.05);
  }

  .feature-text h3 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }

  .feature-text p {
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-text);
  }

  @media (max-width: 992px) {
    .flex-support {
      flex-direction: column;
    }
  }
</style>
