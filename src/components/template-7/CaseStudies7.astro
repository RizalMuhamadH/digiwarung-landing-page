---
import { Image } from "astro:assets";
import case1 from "../../assets/template-7/case-study-1.png";
import case2 from "../../assets/template-7/case-study-2.png";
---

<section class="case-studies-7">
  <div class="container-narrow text-center">
    <h3>Studi kasus clipper pake Clipcash AI Sistem💰</h3>
    <p class="hint">➡️scroll ke samping➡️</p>
    
    <div class="case-slider">
      <div class="case-item">
        <Image src={case1} alt="Case Study 1" class="case-img" />
        <p>Potensi Income 10jt/bulan</p>
      </div>
      <div class="case-item">
        <Image src={case2} alt="Case Study 2" class="case-img" />
        <p>Generate 50+ Klip Viral</p>
      </div>
      <div class="case-item">
        <div class="case-placeholder">
           <span>Bukti Transfer #1</span>
        </div>
        <p>Monetisasi TikTok Affiliate</p>
      </div>
    </div>
  </div>
</section>

<style>
  .case-studies-7 {
    padding: 60px 0;
    background: #f9f9f9;
    border-top: 1px dashed #ddd;
    border-bottom: 1px dashed #ddd;
  }

  .container-narrow {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  h3 {
    font-size: 20px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .hint {
    font-size: 12px;
    color: #999;
    font-weight: 600;
    margin-bottom: 32px;
  }

  .case-slider {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 20px;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .case-slider::-webkit-scrollbar {
    display: none;
  }

  .case-item {
    min-width: 280px;
    background: white;
    padding: 16px;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    text-align: center;
  }

  .case-img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .case-placeholder {
    width: 100%;
    height: 180px;
    background: #eee;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .case-item p {
    font-size: 14px;
    font-weight: 700;
    color: #1a1a1a;
  }
</style>
