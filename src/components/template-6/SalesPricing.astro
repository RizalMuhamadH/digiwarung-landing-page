<section id="pricing" class="sales-pricing section">
  <div class="container-narrow">
    <div class="pricing-container">
      <div class="pricing-box">
        <div class="pricing-header text-center">
          <p class="regular-price">REGULAR PRICE: <span class="strikethrough">$1,997</span> | <span class="special">SPECIAL OFFER: $497</span></p>
          <p class="sub-price">YOUR PRIICE: $1.997 | PIGIKI VALUE: $497: $4/99</p>
          <div class="risk-free">RISK-FREE 30-DAY GUARANTEE</div>
        </div>
        
        <div class="guarantee-badges">
          <div class="badge-item">
            <div class="badge-circle">30</div>
            <span>30-DAY GUARANTEE</span>
          </div>
          <div class="badge-item">
             <div class="badge-icon">🔒</div>
             <span>SECURE CHECKOUT</span>
          </div>
        </div>

        <div class="pricing-action">
           <a href="#" class="btn-buy">GET STARTED NOW</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sales-pricing {
    padding: 100px 0;
    background: #fdfdfd;
  }

  .container-narrow {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .pricing-box {
    background: white;
    border: 3px solid #1a1a1a;
    border-radius: 12px;
    padding: 60px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.1);
  }

  .regular-price {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .strikethrough {
    text-decoration: line-through;
    color: #666;
  }

  .special {
    color: #d32f2f;
  }

  .sub-price {
    font-size: 14px;
    color: #666;
    margin-bottom: 24px;
    font-weight: 600;
  }

  .risk-free {
    background: #1a1a1a;
    color: white;
    display: inline-block;
    padding: 8px 24px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 1px;
    margin-bottom: 40px;
  }

  .guarantee-badges {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 48px;
  }

  .badge-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .badge-circle {
    width: 60px;
    height: 60px;
    border: 3px solid #ffeb3b;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: 900;
  }

  .badge-icon {
    font-size: 32px;
  }

  .badge-item span {
    font-size: 12px;
    font-weight: 800;
    color: #666;
  }

  .btn-buy {
    display: block;
    width: 100%;
    background: #ffeb3b;
    color: #1a1a1a;
    padding: 24px;
    border-radius: 12px;
    font-size: 24px;
    font-weight: 900;
    text-align: center;
    text-decoration: none;
    box-shadow: 0 15px 30px rgba(255, 235, 59, 0.4);
    transition: transform 0.3s;
  }

  .btn-buy:hover {
    transform: scale(1.02);
  }

  @media (max-width: 768px) {
    .pricing-box { padding: 40px 20px; }
    .regular-price { font-size: 18px; }
    .guarantee-badges { gap: 24px; }
  }
</style>
