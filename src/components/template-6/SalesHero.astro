---
import { Image } from "astro:assets";
import instructorImg from "../../assets/template-6/instructor.png";
---

<section id="home" class="sales-hero">
  <div class="container-narrow">
    <div class="hero-top text-center">
      <h1 class="main-headline">
        Discover the Exact Blueprint to <br />
        <span class="text-red"
          >Launch & Scale Your Profitable 6-Figure Online Business in 2024!</span
        >
      </h1>
      <div class="yellow-highlight">
        <strong>Stop Dreaming. Start Building.</strong> Master the Strategies the
        Pro's Use to Achieve Financial Freedom!
      </div>
    </div>

    <div class="hero-main-flex">
      <div class="hero-text">
        <h2>
          Hello Entrepreneur! <br /> Are you ready to escape the 9-to-5 grind and
          build a thriving online empire?
        </h2>
        <p>
          Now, digital working to start top how trending the e-tope accumulate
          what to sad to trodrww and build it <strong
            >challengins your digital entrepreneurship course today!</strong>
        </p>

        <div class="why-now">
          <h3>WHY YOU NEED THIS blueprint TODAY!</h3>
          <ul>
            <li>Launch Scale Your Digital Wealth (1 involvement)</li>
            <li>Made $10k in Month 1! Pro's Exker Financial Bowth!</li>
            <li>Wants-Ssed Yaurr Profitable Online Business?</li>
            <li>Starteglious like Pro's Use to Figure Online Business!</li>
          </ul>
        </div>
      </div>

      <div class="hero-visual">
        <div class="video-mock">
          <Image src={instructorImg} alt="Instructor" class="instructor-img" />
          <div class="play-btn-large"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sales-hero {
    padding: 80px 0;
    background: white;
  }

  .container-narrow {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .main-headline {
    font-size: 48px;
    font-weight: 900;
    line-height: 1.2;
    color: #1a1a1a;
    margin-bottom: 32px;
  }

  .text-red {
    color: #d32f2f;
  }

  .yellow-highlight {
    background: #ffeb3b;
    padding: 12px 24px;
    display: inline-block;
    font-size: 18px;
    color: #1a1a1a;
    border-radius: 4px;
    margin-bottom: 60px;
  }

  .hero-main-flex {
    display: flex;
    gap: 60px;
    align-items: flex-start;
  }

  .hero-text {
    flex: 1.2;
  }

  .hero-text h2 {
    font-size: 28px;
    font-weight: 800;
    margin-bottom: 24px;
    line-height: 1.3;
  }

  .hero-text p {
    font-size: 18px;
    color: #444;
    line-height: 1.6;
    margin-bottom: 40px;
  }

  .why-now h3 {
    font-size: 20px;
    font-weight: 900;
    color: #d32f2f;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .why-now ul {
    list-style: none;
    padding: 0;
  }

  .why-now li {
    padding-left: 32px;
    position: relative;
    margin-bottom: 16px;
    font-size: 16px;
    font-weight: 600;
  }

  .why-now li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #d32f2f;
    font-weight: 900;
    font-size: 20px;
  }

  .hero-visual {
    flex: 1;
  }

  .video-mock {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
  }

  .instructor-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .play-btn-large {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80px;
    height: 80px;
    background: rgba(211, 47, 47, 0.9);
    border-radius: 50%;
    cursor: pointer;
  }

  .play-btn-large::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 55%;
    transform: translate(-50%, -50%);
    border-left: 20px solid white;
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
  }

  @media (max-width: 992px) {
    .main-headline {
      font-size: 32px;
    }
    .hero-main-flex {
      flex-direction: column;
    }
    .hero-visual {
      width: 100%;
    }
  }
</style>
