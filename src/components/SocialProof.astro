---
---
<section class="social-proof">
  <div class="container">
    <h2 class="text-center">More than 25,000 teams use Collabs</h2>
    <div class="logos-grid">
      <div class="logo-item">
        <span class="logo-icon">U</span>
        <span>Unsplash</span>
      </div>
      <div class="logo-item">
        <span class="logo-icon">N</span>
        <span>Notion</span>
      </div>
      <div class="logo-item">
        <span class="logo-icon">I</span>
        <span>INTERCOM</span>
      </div>
      <div class="logo-item">
        <span class="logo-icon">D</span>
        <span>descript</span>
      </div>
      <div class="logo-item">
        <span class="logo-icon">G</span>
        <span>grammarly</span>
      </div>
    </div>
  </div>
</section>

<style>
  .social-proof {
    padding: 80px 0;
    background-color: var(--color-white);
  }

  h2 {
    font-size: 44px;
    font-weight: 800;
    margin-bottom: 60px;
    letter-spacing: -1px;
  }

  .logos-grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 60px;
    opacity: 0.5;
  }

  .logo-item {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 28px;
    font-weight: 700;
    color: var(--color-text-muted);
    filter: grayscale(100%);
    transition: var(--transition);
  }

  .logo-item:hover {
    filter: grayscale(0%);
    opacity: 1;
  }

  .logo-icon {
    width: 32px;
    height: 32px;
    background: #eee;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
  }

  @media (max-width: 768px) {
    h2 { font-size: 28px; }
    .logos-grid { justify-content: center; }
  }
</style>
