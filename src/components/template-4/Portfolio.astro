---
import { Image } from "astro:assets";
import p1 from "../../assets/template-4/portfolio-1.png";
import p2 from "../../assets/template-4/portfolio-2.png";
import p3 from "../../assets/template-4/portfolio-3.png";
import p4 from "../../assets/template-4/portfolio-4.png";
---

<section id="portfolio" class="portfolio-section section">
  <div class="container">
    <div class="section-header">
      <h2>We Create World-Class Digital Products</h2>
      <p>By information about design the world to the best instructors, treats helping by information</p>
    </div>

    <div class="portfolio-grid">
      <!-- Large Featured Item -->
      <div class="portfolio-item large">
        <div class="image-box">
           <Image src={p1} alt="Project 1" class="p-img" />
        </div>
        <div class="p-info">
          <p class="p-category">App Design • June 20, 2022</p>
          <h3>App Redesign</h3>
          <p class="p-desc">By information about design the world to the best instructors, treats helping by information about design the world to the best instructors, treats helping</p>
        </div>
      </div>

      <!-- Small Items Grid -->
      <div class="small-grid">
        <div class="portfolio-item small">
          <div class="image-box">
             <Image src={p2} alt="Project 2" class="p-img" />
          </div>
          <div class="p-info">
            <p class="p-category">App Design • June 20, 2022</p>
            <h3>Redesign Channel Website Landing Page</h3>
          </div>
        </div>

        <div class="portfolio-item small">
          <div class="image-box">
             <Image src={p3} alt="Project 3" class="p-img" />
          </div>
          <div class="p-info">
            <p class="p-category">App Design • June 20, 2022</p>
            <h3>New Locator App For a New Company</h3>
          </div>
        </div>

        <div class="portfolio-item small">
          <div class="image-box">
             <Image src={p4} alt="Project 4" class="p-img" />
          </div>
          <div class="p-info">
            <p class="p-category">App Design • June 20, 2022</p>
            <h3>Bantai Roosu Web App Platform</h3>
          </div>
        </div>

        <div class="portfolio-item small">
          <div class="image-box">
             <Image src={p2} alt="Project 5" class="p-img" />
          </div>
          <div class="p-info">
            <p class="p-category">App Design • June 20, 2022</p>
            <h3>Calendar App For Big SaaS Company</h3>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .portfolio-section {
    padding: 100px 0;
  }

  .section-header {
    margin-bottom: 60px;
  }

  .section-header h2 {
    font-size: 40px;
    font-weight: 800;
    margin-bottom: 16px;
    max-width: 600px;
  }

  .section-header p {
    font-size: 18px;
    color: #666;
    max-width: 700px;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 40px;
  }

  .portfolio-item {
    background: #fff;
    border-radius: 24px;
    overflow: hidden;
  }

  .image-box {
    width: 100%;
    height: 300px;
    overflow: hidden;
    border-radius: 20px;
  }

  .large .image-box {
    height: 500px;
  }

  .small .image-box {
    height: 220px;
  }

  .p-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .portfolio-item:hover .p-img {
    transform: scale(1.05);
  }

  .p-info {
    padding: 24px 0;
  }

  .p-category {
    font-size: 14px;
    font-weight: 600;
    color: #666;
    margin-bottom: 12px;
  }

  .p-info h3 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 12px;
  }

  .p-desc {
    font-size: 16px;
    color: #666;
    line-height: 1.6;
  }

  .small-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .small h3 {
    font-size: 18px;
  }

  @media (max-width: 992px) {
    .portfolio-grid { grid-template-columns: 1fr; }
    .small-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 576px) {
    .small-grid { grid-template-columns: 1fr; }
  }
</style>
